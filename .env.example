# ============================================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE — copie para .env e preencha
# O arquivo .env está no .gitignore e NUNCA deve ser comitado
# ============================================================

# Banco de Dados (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gestao_vagas
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Segredos JWT — gere valores fortes para produção:
#   openssl rand -base64 32
SECURITY_TOKEN_SECRET=your_jwt_secret_here
SECURITY_TOKEN_CANDIDATE=your_jwt_candidate_secret_here

# SonarQube — obtenha em: SonarQube > My Account > Security > Generate Token
TOKEN_SONARQUBE=your_sonarqube_token_here
